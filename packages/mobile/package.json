{
  "name": "@trizum/mobile",
  "version": "1.10.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "Horus Lugo <hola@horus.dev> (https://horus.dev)",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#*": "./*"
  },
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "capacitor:copy:before": "./copy-client.sh",
    "cleanup": "rm -rf dist",
    "dev": "tsc --watch",
    "open:android": "vp exec cap open android",
    "open:ios": "vp exec cap open ios",
    "run:android": "vp exec cap run android",
    "run:ios": "vp exec cap run ios",
    "dev:android": "DEV_MODE=true vp run run:android",
    "dev:ios": "DEV_MODE=true vp run run:ios",
    "assets:generate": "./generate-icons.sh",
    "version:update": "vp exec capver set $(node -p \"require('./package.json').version\")"
  },
  "dependencies": {
    "@capacitor/android": "8.0.1",
    "@capacitor/app": "8.0.0",
    "@capacitor/camera": "8.2.0",
    "@capacitor/core": "8.0.1",
    "@capacitor/ios": "8.0.1",
    "@capacitor/share": "8.0.0",
    "@capacitor/splash-screen": "8.0.0",
    "@capawesome/capacitor-app-update": "8.0.3",
    "@capawesome/capacitor-apple-sign-in": "0.1.0",
    "@capawesome/capacitor-google-sign-in": "0.1.2",
    "@trizum/logging": "workspace:*",
    "@trizum/pwa": "workspace:*",
    "capacitor-plugin-safe-area": "5.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "3.0.5",
    "@capacitor/cli": "8.0.1",
    "@capawesome/capver": "0.1.0",
    "@trizum/tsconfig": "workspace:*",
    "@types/node": "^24.10.1",
    "sharp": "0.32.6",
    "svgexport": "0.4.2",
    "typescript": "5.9.2"
  }
}
