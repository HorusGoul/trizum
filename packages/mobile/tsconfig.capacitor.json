{
  "extends": "@trizum/tsconfig/base.json",
  "include": ["capacitor.config.ts", "capacitor.log.ts"],
  "exclude": ["dist", "node_modules"],
  "compilerOptions": {
    "types": ["node"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "target": "ES2017",
    "noEmit": false,
    "verbatimModuleSyntax": false,
    "baseUrl": ".",
    "paths": {
      "@trizum/logging": ["../logging/src/index.ts"]
    }
  }
}
