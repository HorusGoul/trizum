{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "trizum-preview",
  "compatibility_date": "2025-11-18",
  "main": "dist/trizum/index.js",
  "no_bundle": true,
  "rules": [
    {
      "type": "ESModule",
      "globs": ["**/*.js", "**/*.mjs"],
    },
  ],
  "assets": {
    "directory": "./dist/client",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"],
  },
  "preview_urls": true,
  "workers_dev": true,
}
