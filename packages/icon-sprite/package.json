{
  "name": "@trizum/icon-sprite",
  "version": "1.0.0",
  "private": true,
  "description": "Reusable SVG sprite generation and Vite integration.",
  "keywords": [],
  "license": "MIT",
  "author": "Horus Lugo <hola@horus.dev> (https://horus.dev)",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#*": "./*"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "default": "./dist/vite.js"
    }
  },
  "scripts": {
    "check": "vp check .",
    "cleanup": "rm -rf dist",
    "dev": "tsc -b tsconfig.json --watch",
    "build": "tsc -b tsconfig.json",
    "test": "vp test ."
  },
  "dependencies": {
    "svgo": "4.0.1"
  },
  "devDependencies": {
    "@trizum/tsconfig": "workspace:*",
    "typescript": "5.9.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
