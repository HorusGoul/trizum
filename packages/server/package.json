{
  "name": "@trizum/server",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "Horus Lugo <hola@horus.dev> (https://horus.dev)",
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#*": "./*"
  },
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "cleanup": "rm -rf dist",
    "dev": "vp run node --watch src/main.ts",
    "start": "vp run node --import ./src/instrument.ts src/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "vp lint src",
    "lint:fix": "vp lint src --fix",
    "node": "NODE_OPTIONS=--disable-warning=ExperimentalWarning node --experimental-transform-types",
    "db:drizzle": "vp run node node_modules/drizzle-kit/bin.cjs",
    "db:generate": "vp run db:drizzle generate",
    "db:migrate": "vp run db:drizzle migrate",
    "db:studio": "vp run db:drizzle studio",
    "db:push": "vp run db:drizzle push",
    "deploy": "./deploy.sh"
  },
  "dependencies": {
    "@automerge/automerge-repo": "2.5.3",
    "@automerge/automerge-repo-network-websocket": "2.5.3",
    "@hono/node-server": "1.19.6",
    "@hono/node-ws": "1.2.0",
    "@kubiks/otel-drizzle": "2.1.0",
    "@libsql/client": "0.15.15",
    "@logtape/logtape": "1.2.2",
    "@logtape/sentry": "1.2.2",
    "@sentry/node": "10.29.0",
    "@sentry/profiling-node": "10.29.0",
    "@trizum/logging": "workspace:*",
    "drizzle-kit": "0.31.7",
    "drizzle-orm": "0.44.7",
    "hono": "4.10.6",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@trizum/tsconfig": "workspace:*",
    "@types/node": "24.10.1",
    "typescript": "5.9.2"
  }
}
