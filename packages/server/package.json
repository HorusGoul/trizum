{
  "name": "@trizum/server",
  "version": "1.0.2",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "Horus Lugo <hola@horus.dev> (https://horus.dev)",
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#*": "./*"
  },
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "cleanup": "rm -rf dist",
    "dev": "vp run node --watch src/main.ts",
    "start": "NODE_OPTIONS=--disable-warning=ExperimentalWarning node --experimental-transform-types --import ./src/instrument.ts src/main.ts",
    "node": "NODE_OPTIONS=--disable-warning=ExperimentalWarning node --experimental-transform-types",
    "db:drizzle": "NODE_OPTIONS=--disable-warning=ExperimentalWarning node --experimental-transform-types node_modules/drizzle-kit/bin.cjs",
    "db:generate": "NODE_OPTIONS=--disable-warning=ExperimentalWarning node --experimental-transform-types node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "NODE_OPTIONS=--disable-warning=ExperimentalWarning node --experimental-transform-types node_modules/drizzle-kit/bin.cjs migrate",
    "db:studio": "NODE_OPTIONS=--disable-warning=ExperimentalWarning node --experimental-transform-types node_modules/drizzle-kit/bin.cjs studio",
    "db:push": "NODE_OPTIONS=--disable-warning=ExperimentalWarning node --experimental-transform-types node_modules/drizzle-kit/bin.cjs push",
    "deploy": "./deploy.sh"
  },
  "dependencies": {
    "@automerge/automerge": "catalog:",
    "@automerge/automerge-repo": "catalog:",
    "@automerge/automerge-repo-network-websocket": "catalog:",
    "@hono/node-server": "catalog:",
    "@kubiks/otel-drizzle": "catalog:",
    "@libsql/client": "catalog:",
    "@logtape/logtape": "catalog:",
    "@logtape/sentry": "catalog:",
    "@sentry/node": "catalog:",
    "@sentry/profiling-node": "catalog:",
    "@trizum/logging": "workspace:*",
    "drizzle-kit": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "isomorphic-ws": "catalog:",
    "ws": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@trizum/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/ws": "catalog:",
    "typescript": "catalog:"
  }
}
