{
  "name": "@trizum/ts-template",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "Horus Lugo <hola@horus.dev> (https://horus.dev)",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#*": "./*"
  },
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "cleanup": "rm -rf dist",
    "dev": "tsc -b tsconfig.json --watch",
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -b tsconfig.test.json",
    "lint": "vp lint src",
    "lint:fix": "vp lint src --fix",
    "test": "vp test run"
  },
  "dependencies": {
    "@trizum/logging": "workspace:*"
  },
  "devDependencies": {
    "@trizum/tsconfig": "workspace:*",
    "typescript": "5.9.2",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
