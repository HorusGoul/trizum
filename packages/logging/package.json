{
  "name": "@trizum/logging",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "Horus Lugo <hola@horus.dev> (https://horus.dev)",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#*": "./*"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./github-actions": {
      "types": "./dist/github-actions.d.ts",
      "source": "./src/github-actions.ts",
      "import": "./dist/github-actions.js",
      "default": "./dist/github-actions.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "check": "vp check .",
    "cleanup": "rm -rf dist",
    "dev": "tsc -b tsconfig.json --watch",
    "test": "vp test ."
  },
  "dependencies": {
    "@logtape/logtape": "1.2.2"
  },
  "devDependencies": {
    "@trizum/tsconfig": "workspace:*",
    "typescript": "5.9.2",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
