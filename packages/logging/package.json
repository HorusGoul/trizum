{
  "name": "@trizum/logging",
  "description": "",
  "keywords": [],
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "author": "Horus Lugo <hola@horus.dev> (https://horus.dev)",
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "type": "module",
  "imports": {
    "#*": "./*"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./github-actions": {
      "types": "./src/github-actions.ts",
      "import": "./src/github-actions.ts",
      "default": "./src/github-actions.ts"
    }
  },
  "scripts": {
    "cleanup": "rm -rf dist",
    "lint": "eslint --ext .ts src",
    "lint:fix": "pnpm run lint --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@logtape/logtape": "1.2.2"
  },
  "devDependencies": {
    "@trizum/eslint-config": "workspace:*",
    "@trizum/prettier-config": "workspace:*",
    "@trizum/tsconfig": "workspace:*",
    "eslint": "9.39.1",
    "prettier": "3.6.2",
    "typescript": "5.9.2",
    "vitest": "4.1.0"
  },
  "prettier": "@trizum/prettier-config"
}
