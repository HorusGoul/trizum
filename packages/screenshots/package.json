{
  "name": "@trizum/screenshots",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "Horus Lugo <hola@horus.dev> (https://horus.dev)",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#*": "./*"
  },
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "cleanup": "rm -rf .captures screenshots",
    "compose": "node --experimental-transform-types src/compose-existing.ts",
    "start": "node --experimental-transform-types src/main.ts",
    "organize:fastlane": "node --experimental-transform-types src/organize-for-fastlane.ts",
    "preview": "node --experimental-transform-types src/generate-previews.ts",
    "setup": "vp exec playwright install --with-deps --only-shell chromium"
  },
  "dependencies": {
    "@trizum/logging": "workspace:*",
    "playwright": "catalog:"
  },
  "devDependencies": {
    "@trizum/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native": "catalog:"
  }
}
