{
  "name": "@trizum/screenshots",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "Horus Lugo <hola@horus.dev> (https://horus.dev)",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#*": "./*"
  },
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "cleanup": "rm -rf screenshots",
    "start": "vp node --experimental-transform-types src/main.ts",
    "organize:fastlane": "vp node --experimental-transform-types src/organize-for-fastlane.ts",
    "typecheck": "tsc --noEmit",
    "lint": "vp lint src",
    "lint:fix": "vp lint src --fix",
    "setup": "vp exec playwright install --with-deps --only-shell chromium"
  },
  "dependencies": {
    "@trizum/logging": "workspace:*",
    "playwright": "1.60.0"
  },
  "devDependencies": {
    "@trizum/tsconfig": "workspace:*",
    "@types/node": "24.10.2",
    "typescript": "5.9.2"
  }
}
