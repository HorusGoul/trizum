{
  "name": "root",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "author": "Horus Lugo <hola@horus.dev>",
  "scripts": {
    "agent-browser": "agent-browser",
    "agent-browser:install": "agent-browser install",
    "browserslist:update-db": "vp dlx update-browserslist-db@latest",
    "build": "vp run -r build",
    "lingui:extract": "vp run --filter @trizum/pwa lingui:extract",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "publish-packages": "vp exec changeset publish",
    "test:e2e": "vp run --filter @trizum/pwa test:e2e",
    "update-version": "vp exec changeset version && cd packages/mobile && vp run version:update",
    "syncpack:fix": "vp exec syncpack fix-mismatches && vp exec syncpack format",
    "typecheck": "vp check --no-fmt --no-lint",
    "generate:ts-template": "vp exec turbo gen workspace --copy @trizum/ts-template --type package",
    "prepare": "vp config && node scripts/apply-vite-plus-agent-overrides.mjs",
    "doctor": "vpx react-doctor"
  },
  "dependencies": {
    "@changesets/cli": "2.29.8",
    "@sentry/cli": "3.1.0",
    "@turbo/gen": "2.5.6",
    "agent-browser": "0.20.13",
    "all-contributors-cli": "6.26.1",
    "skills": "1.4.5",
    "syncpack": "12.3.3",
    "turbo": "2.5.6"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "9.39.1",
    "eslint-plugin-lingui": "0.11.0",
    "oxlint-plugin-react-doctor": "0.5.8",
    "react-doctor": "0.5.8",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": "^24"
  },
  "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316",
  "pnpm": {
    "onlyBuiltDependencies": [
      "agent-browser",
      "@sentry-internal/node-cpu-profiler",
      "@sentry/cli",
      "@swc/core",
      "cbor-extract",
      "core-js-pure",
      "esbuild",
      "puppeteer",
      "sharp",
      "unrs-resolver",
      "workerd"
    ]
  }
}
